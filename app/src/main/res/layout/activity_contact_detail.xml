<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EFE0D5"
    android:padding="24dp">

    <!-- Avatar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/card_bg"
        android:padding="24dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvDetailInitial"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:gravity="center"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#F7EDE6"
            android:background="@drawable/circle_bg" />

        <TextView
            android:id="@+id/tvDetailName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#3D2229"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tvDetailPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#5A5A5F"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- Info Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="20dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Details"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#3D2229"
            android:paddingBottom="10dp" />

        <TextView
            android:id="@+id/tvDetailSource"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#5A5A5F" />

        <TextView
            android:id="@+id/tvDetailDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#5A5A5F"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- Duplicate Warning Card -->
    <LinearLayout
        android:id="@+id/cardDuplicates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_warning_bg"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ Shared number detected"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#7B3F00"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvDuplicateNames"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#7B3F00" />

    </LinearLayout>

</LinearLayout>